{
  "expo": {
    "name": "wdiodemoapp",
    "slug": "wdiodemoapp",
    "version": "2.2.0",
    "orientation": "portrait",
    "icon": "./src/assets/webdriverio.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./src/assets/webdriverio.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "org.wdiodemoapp",
      "buildNumber": "20",
      "infoPlist": {
        "NSFaceIDUsageDescription": "wdiodemoapp requires FaceID access to allows you quick and secure access.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/webdriverio.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.wdiodemoapp",
      "versionCode": 21,
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./src/assets/webdriverio.png"
    },
    "scheme": "wdio",
    "plugins": [
      "./plugins/withIosSimulatorExcludedArchs.js",
      [
        "expo-dev-client",
        {
          "launchMode": "most-recent"
        }
      ],
      "expo-local-authentication",
      "expo-splash-screen",
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow wdiodemoapp to use the camera for automated tests.",
          "microphonePermission": "Allow wdiodemoapp to use the microphone for automated tests.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow wdiodemoapp to use your location while using the app for automated tests."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow wdiodemoapp to access your photos for automated tests.",
          "savePhotosPermission": "Allow wdiodemoapp to save photos for automated tests.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      "expo-secure-store",
      "expo-sqlite"
    ],
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
